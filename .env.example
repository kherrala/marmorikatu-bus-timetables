# Default walk time in minutes (used for stops without a specific override)
WALKING_TIME_MINUTES=10

# Per-stop walk times: stopId:minutes comma-separated (overrides WALKING_TIME_MINUTES)
STOP_WALKING_TIMES=4431:6,4087:11

# Explicit stop IDs to monitor — use city-direction stops only.
# Kaipanen city-direction: 4431, Pitkäniitynkatu city-direction: 4087
STOP_IDS=4431,4087

# Stop names for auto-discovery (comma-separated, used only if STOP_IDS is not set)
# STOP_NAMES=Kaipanen,Pitkäniitynkatu

# Displayed in dashboard header
HOME_ADDRESS=Your Address, City

# How far ahead to show departures (minutes)
LOOKAHEAD_MINUTES=90

# Destination headsign filter — leave empty to show all buses from these stops
CITY_CENTER_PATTERNS=

# Alert feature defaults (true/false). Can be toggled per-device in the in-app settings panel.
ALERT_BAR=true
ALERT_OVERLAY=true

# Server port
PORT=3000

# ITS Factory Journeys API base URL
API_BASE_URL=http://data.itsfactory.fi/journeys/api/1

# Maanmittauslaitos open API key for taustakartta tiles (optional)
# Get a free key at: https://www.maanmittauslaitos.fi/kartat-ja-paikkatieto/rajapinnat-ja-aineistot/karttakuvat-wmts
# If not set, CartoDB dark tiles are used instead.
# MML_API_KEY=your-api-key-here
